        "kind": "Panel",
        "spec": {
          "display": {
            "name": "BackupStorage",
            "description": "List of BackupStorages currently exist in the cluster"
          },
          "plugin": {
            "kind": "Table",
            "spec": {
              "columnSettings": [
                {
                  "format": {
                    "unit": "bytes"
                  },
                  "name": "Size"
                },
                {
                  "name": "Provider",
                  "width": 100
                },
                {
                  "name": "Default",
                  "width": 100
                },
                {
                  "name": "Deletion Policy",
                  "width": 110
                },
                {
                  "name": "Phase",
                  "width": 100
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "datasource": {
                      "kind": "PrometheusDatasource",
                      "name": "global-ds-proxy"
                    },
                    "minStep": "",
                    "query": "storage_kubestash_com_backupstorage_info{namespace=~\"${namespace}\"}",
                    "seriesNameFormat": ""
                  }
                }
              }
            },
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "datasource": {
                      "kind": "PrometheusDatasource",
                      "name": "global-ds-proxy"
                    },
                    "query": "storage_kubestash_com_backupstorage_size_bytes{namespace=~\"${namespace}\"}",
                    "seriesNameFormat": ""
                  }
                }
              }
            }
          ]
        }
      },
